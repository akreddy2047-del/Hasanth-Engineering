{
  "entities": {
    "Job": {
      "title": "Job Posting",
      "description": "A job opportunity at the company.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "exp": { "type": "string" },
        "skills": { "type": "array", "description": "List of required skills" },
        "desc": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "location", "exp", "desc", "skills", "timestamp"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Information from a candidate applying for a job.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "applicantName": { "type": "string" },
        "applicantEmail": { "type": "string", "format": "email" },
        "applicantPhone": { "type": "string" },
        "portfolioLink": { "type": "string" },
        "coverLetter": { "type": "string" },
        "resumeName": { "type": "string" },
        "resumeData": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "applicantName", "applicantEmail", "timestamp"]
    },
    "Enquiry": {
      "title": "Enquiry",
      "description": "Contact form submissions.",
      "type": "object",
      "properties": {
        "applicantName": { "type": "string" },
        "applicantEmail": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "industry": { "type": "string" },
        "serviceType": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["applicantName", "applicantEmail", "subject", "message", "timestamp"]
    },
    "Blog": {
      "title": "Blog Post",
      "description": "A technical paper or blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "readingTime": { "type": "string" },
        "bgUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "featured": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "excerpt", "content", "category", "readingTime", "timestamp", "status"]
    },
    "BlogCategory": {
      "title": "Blog Category",
      "description": "Categories for blog posts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "timestamp"]
    },
    "Legal": {
      "title": "Legal Page",
      "description": "Content for legal pages like Privacy Policy and Terms & Conditions.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["privacy", "terms"] },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        }
      },
      "required": ["type", "content", "lastUpdated", "sections"]
    },
    "Project": {
      "title": "Engineering Project",
      "description": "Selected blueprints and corporate project archives.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "specs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl", "description", "specs", "timestamp"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Customizable content for various pages on the website.",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "heading": { "type": "string" },
              "body": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["pageId", "lastUpdated"]
    }
  },
  "firestore": {
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications"
    },
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "Contact inquiries"
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Technical blog posts"
    },
    "/blog_categories/{categoryId}": {
      "schema": "BlogCategory",
      "description": "Blog categories"
    },
    "/legal/{pageType}": {
      "schema": "Legal",
      "description": "Legal pages content"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project portfolio items"
    },
    "/page_content/{pageId}": {
      "schema": "PageContent",
      "description": "Website page content management"
    }
  }
}
