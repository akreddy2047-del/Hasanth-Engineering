rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function isValidString(val, maxLen) { return val is string && val.size() <= maxLen; }

    match /jobs/{jobId} {
      allow read: if true;
      
      function isValidJob(data) {
        return data.keys().hasAll(['title', 'type', 'location', 'exp', 'desc', 'skills', 'timestamp'])
          && data.keys().size() == 7
          && isValidString(data.title, 200)
          && isValidString(data.type, 100)
          && isValidString(data.location, 200)
          && isValidString(data.exp, 200)
          && isValidString(data.desc, 10000)
          && data.skills is list && data.skills.size() <= 50;
      }
      
      allow create, update: if isValidJob(incoming());
      allow delete: if true;
    }

    match /applications/{applicationId} {
      allow read: if true; // In production, this should be restricted to admin
      
      function isValidApplication(data) {
        return data.keys().hasAll(['jobId', 'applicantName', 'applicantEmail', 'timestamp'])
          && data.keys().size() >= 4 && data.keys().size() <= 10
          && isValidString(data.jobId, 500)
          && isValidString(data.applicantName, 500)
          && isValidString(data.applicantEmail, 500)
          && (!("applicantPhone" in data.keys()) || isValidString(data.applicantPhone, 100))
          && (!("coverLetter" in data.keys()) || isValidString(data.coverLetter, 10000))
          && (!("portfolioLink" in data.keys()) || isValidString(data.portfolioLink, 1000))
          && (!("resumeName" in data.keys()) || data.resumeName == null || isValidString(data.resumeName, 500))
          && (!("resumeData" in data.keys()) || data.resumeData == null || isValidString(data.resumeData, 5000000));
      }
      
      allow create, update: if isValidApplication(incoming());
      allow delete: if true;
    }

    match /enquiries/{enquiryId} {
      allow read: if true;
      
      function isValidEnquiry(data) {
        return data.keys().hasAll(['applicantName', 'applicantEmail', 'subject', 'message', 'timestamp'])
          && isValidString(data.applicantName, 500)
          && isValidString(data.applicantEmail, 500)
          && isValidString(data.subject, 1000)
          && isValidString(data.message, 20000)
          && (!('type' in data.keys()) || isValidString(data.type, 100))
          && (!('phone' in data.keys()) || isValidString(data.phone, 100))
          && (!('company' in data.keys()) || isValidString(data.company, 500))
          && (!('industry' in data.keys()) || isValidString(data.industry, 200))
          && (!('serviceType' in data.keys()) || isValidString(data.serviceType, 500))
          && (!('executionTimeframe' in data.keys()) || isValidString(data.executionTimeframe, 500));
      }
      
      allow create, update: if isValidEnquiry(incoming());
      allow delete: if true;
    }

    match /blogs/{blogId} {
      allow read: if true;
      
      function isValidBlog(data) {
        return data.keys().hasAll(['title', 'excerpt', 'content', 'category', 'readingTime', 'timestamp', 'status'])
          && isValidString(data.title, 2000)
          && isValidString(data.excerpt, 5000)
          && isValidString(data.content, 2000000)
          && isValidString(data.category, 500)
          && isValidString(data.readingTime, 200)
          && isValidString(data.status, 50)
          && (!('featured' in data.keys()) || data.featured is bool)
          && (!('author' in data.keys()) || isValidString(data.author, 500))
          && (!('date' in data.keys()) || isValidString(data.date, 200))
          && (!('bgUrl' in data.keys()) || isValidString(data.bgUrl, 2000));
      }
      
      allow create, update: if isValidBlog(incoming());
      allow delete: if true;
    }

    match /blog_categories/{categoryId} {
      allow read: if true;
      
      function isValidCategory(data) {
        return data.keys().hasAll(['name', 'slug', 'timestamp'])
          && isValidString(data.name, 200)
          && isValidString(data.slug, 200);
      }
      
      allow create, update: if isValidCategory(incoming());
      allow delete: if true;
    }

    match /legal/{pageType} {
      allow read: if true;
      
      function isValidLegal(data) {
        return data.keys().hasAll(['type', 'content', 'lastUpdated', 'sections'])
          && isValidString(data.type, 100)
          && isValidString(data.content, 20000)
          && data.sections is list;
      }
      
      allow create, update: if isValidLegal(incoming());
      allow delete: if true;
    }

    match /projects/{projectId} {
      allow read: if true;
      
      function isValidProject(data) {
        return data.keys().hasAll(['title', 'category', 'imageUrl', 'description', 'specs', 'timestamp'])
          && isValidString(data.title, 500)
          && isValidString(data.category, 200)
          && isValidString(data.imageUrl, 2000)
          && isValidString(data.description, 5000)
          && data.specs is list;
      }
      
      allow create, update: if isValidProject(incoming());
      allow delete: if true;
    }

    match /page_content/{pageId} {
      allow read: if true;
      
      function isValidPageContent(data) {
        return data.keys().hasAll(['pageId', 'lastUpdated'])
          && isValidString(data.pageId, 200)
          && (!('title' in data.keys()) || isValidString(data.title, 1000))
          && (!('subtitle' in data.keys()) || isValidString(data.subtitle, 2000))
          && (!('content' in data.keys()) || isValidString(data.content, 1000000))
          && (!('imageUrl' in data.keys()) || isValidString(data.imageUrl, 2000))
          && (!('sections' in data.keys()) || data.sections is list);
      }
      
      allow create, update: if isValidPageContent(incoming());
      allow delete: if true;
    }

    match /trust_metrics/{metricId} {
      allow read: if true;
      
      function isValidMetric(data) {
        return data.keys().hasAll(['value', 'label', 'desc', 'timestamp'])
          && isValidString(data.value, 200)
          && isValidString(data.label, 500)
          && isValidString(data.desc, 1000)
          && (!('order' in data.keys()) || data.order is number);
      }
      
      allow create, update: if isValidMetric(incoming());
      allow delete: if true;
    }

    match /site_config/{configId} {
      allow read: if true;
      
      function isValidConfig(data) {
        return (!('whatsappNumber' in data.keys()) || isValidString(data.whatsappNumber, 50))
          && (!('whatsappMessage' in data.keys()) || isValidString(data.whatsappMessage, 2000))
          && (!('contactPhone' in data.keys()) || isValidString(data.contactPhone, 50))
          && (!('contactEmail' in data.keys()) || isValidString(data.contactEmail, 200))
          && (!('contactAddress' in data.keys()) || isValidString(data.contactAddress, 1000))
          && (!('contactAddressShort' in data.keys()) || isValidString(data.contactAddressShort, 200));
      }
      
      allow create, update: if isValidConfig(incoming());
      allow delete: if true;
    }

    match /divisions/{divisionId} {
      allow read: if true;
      
      function isValidDivision(data) {
        return data.keys().hasAll(['title', 'desc', 'icon', 'badge', 'color'])
          && isValidString(data.title, 200)
          && isValidString(data.desc, 2000)
          && isValidString(data.icon, 100)
          && isValidString(data.badge, 200)
          && isValidString(data.color, 100)
          && (!('order' in data.keys()) || data.order is number)
          && (!('bulletPoints' in data.keys()) || data.bulletPoints is list)
          && (!('machines' in data.keys()) || data.machines is list);
      }
      
      allow create, update: if isValidDivision(incoming());
      allow delete: if true;
    }

    match /research/{researchId} {
      allow read: if true;
      
      function isValidResearch(data) {
        return data.keys().hasAll(['title', 'desc', 'imageUrl', 'iconName', 'timestamp'])
          && data.keys().size() == 5
          && isValidString(data.title, 200)
          && isValidString(data.desc, 5000)
          && isValidString(data.imageUrl, 2000)
          && isValidString(data.iconName, 100);
      }
      
      allow create, update: if isValidResearch(incoming());
      allow delete: if true;
    }
  }
}
