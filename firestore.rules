rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Validation Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAuth() { return request.auth != null; }

    // 3. Collection Rules
    
    // Jobs & Vacancies
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if true; // In production, this should be isAuth() but for preview we keep it open for reset
    }

    // Enquiries
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // Applications
    match /applications/{appId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /blog_categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    // Legal Documents
    match /legal/{pageId} {
      allow read: if true;
      allow write: if true;
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true;
    }

    // CMS Page Content
    match /page_content/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
